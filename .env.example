# ── Database ────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://adhd:adhd@localhost:5432/adhd_brain

# ── SenticNet Cloud API ────────────────────────────────
SENTICNET_API_KEY=your_senticnet_api_key_here
SENTICNET_BASE_URL=https://api.sentic.net

# ── Whoop API (OAuth 2.0) ──────────────────────────────
WHOOP_CLIENT_ID=your_whoop_client_id
WHOOP_CLIENT_SECRET=your_whoop_client_secret
WHOOP_REDIRECT_URI=http://localhost:8420/whoop/callback

# ── LLM Keys ───────────────────────────────────────────
CLAUDE_API_KEY=your_claude_api_key
OPENAI_API_KEY=your_openai_api_key

# ── Application Settings ───────────────────────────────
APP_PORT=8420
APP_VERSION=0.1.0
INTERVENTION_COOLDOWN_SECONDS=300
LOG_LEVEL=INFO
