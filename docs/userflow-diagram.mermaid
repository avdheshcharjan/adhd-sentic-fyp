flowchart TD
    %% ── Entry Points ────────────────────────────────────────────
    START([User]) --> LAUNCH[Launch macOS Menu Bar App]
    START --> DASH[Open Web Dashboard]
    START --> TELE[Send Message via Telegram]

    %% ── Swift App Launch ────────────────────────────────────────
    LAUNCH --> PERM{Accessibility\nPermission?}
    PERM -->|Granted| MONITOR[Start Screen Monitoring]
    PERM -->|Not Granted| ONBOARD[Show Onboarding View]
    ONBOARD --> GRANT[User Grants Permission\nin System Preferences]
    GRANT --> MONITOR

    %% ── Continuous Monitoring ───────────────────────────────────
    MONITOR --> CAPTURE[Capture Active App +\nWindow Title + URL\nevery 2-3 seconds]
    CAPTURE --> POST[POST /screen/activity]
    POST --> CLASSIFY[Classify Activity\ndevelopment · social_media · etc.]
    CLASSIFY --> SETFIT[SetFit Emotion Classification\n→ 6 ADHD states · PASE radar]
    SETFIT --> METRICS[Update ADHD Metrics\nfocus score · switches · streak]
    METRICS --> OFFTASK{Focus Session\nActive?}

    %% ── Off-Task Detection ────────────────────────────────────
    OFFTASK -->|Yes| RELEVANCE[Check Embedding Similarity\nTask name vs Current activity]
    RELEVANCE --> OFFTASK_RESULT{Off-Task?}
    OFFTASK_RESULT -->|Yes| OFFTASK_ALERT[Set off_task = true\nSwift shows alert in Notch]
    OFFTASK_RESULT -->|No| JITAI
    OFFTASK_ALERT --> JITAI

    OFFTASK -->|No| JITAI{JITAI\nIntervention\nNeeded?}

    %% ── JITAI Gating ───────────────────────────────────────────
    JITAI -->|No| PERSIST[Persist to DB]
    PERSIST --> CAPTURE

    JITAI -->|Yes| GATES{Pass All Gates?}

    subgraph GATING ["4-Layer Gating System"]
        direction TB
        G0[Gate 0: DND Mode Off?]
        G1[Gate 1: Not in Productive Hyperfocus?]
        G2[Gate 2: Under 3 per 90-min Cap?]
        G3[Gate 3: Thompson Sampling Approves?]
        G0 --> G1 --> G2 --> G3
    end

    GATES -->|Blocked| PERSIST
    GATES -->|Passed| XAI[Generate XAI Explanation\n3-Tier Progressive Disclosure]
    XAI --> BREAKPOINT{User at Natural\nBreakpoint?}

    %% ── Breakpoint Detection ────────────────────────────────────
    BREAKPOINT -->|No| QUEUE[Queue Intervention\nWait for Breakpoint]
    QUEUE --> TIER1

    BREAKPOINT -->|Yes| DELIVER[Deliver Intervention]

    %% ── 5-Tier Calm Notification ────────────────────────────────
    subgraph TIERS ["5-Tier Calm Notification System"]
        direction TB
        TIER1[Tier 1: Ambient Color Shift\nMenu bar changes color]
        TIER2[Tier 2: Pulse Animation\nGentle icon pulse]
        TIER3[Tier 3: Overlay Panel\nNon-focus-stealing popup\nAuto-dismiss 15s]
        TIER4[Tier 4: macOS Toast\nSystem notification]
        TIER5[Tier 5: Full Alert\nOverlay + Toast\nSafety-critical only]
        TIER1 -->|"> 2 min"| TIER2
        TIER2 -->|"Breakpoint"| TIER3
        TIER3 -->|"Ignored"| TIER4
        TIER4 -->|"Critical"| TIER5
    end

    DELIVER --> TIER3

    %% ── Intervention Response ───────────────────────────────────
    TIER3 --> RESPONSE{User Response}
    TIER4 --> RESPONSE
    TIER5 --> RESPONSE

    RESPONSE -->|Accepts Action| RECORD[POST /interventions/respond\nRecord Acceptance]
    RESPONSE -->|Dismisses| DISMISS[Record Dismissal\nIncrease Cooldown]
    RESPONSE -->|Corrects Concept| CORRECT[POST /correct-concept\nUpdate CBM Model]
    RESPONSE -->|Auto-Dismissed| IGNORE[No Response Recorded]

    RECORD --> LEARN[Thompson Sampling\nLearns from Response]
    DISMISS --> LEARN
    LEARN --> CAPTURE

    %% ── XAI Explanation Tiers ───────────────────────────────────
    subgraph EXPLAIN ["XAI Explanation (Tap to Expand)"]
        direction TB
        E1["Tier 1: Traffic Light + Emoji\n🔴 Red — 8 switches in 5 min"]
        E2["Tier 2: One-Sentence Why\n'You've switched apps 8 times\nin 5 min with 67% on non-work apps'"]
        E3["Tier 3: Full Concept Breakdown\n+ Counterfactual + User Correction"]
        E1 -->|Tap| E2 -->|Tap| E3
    end

    %% ── Notch Island States ────────────────────────────────────
    subgraph NOTCH ["Notch Island (5-State Widget)"]
        direction TB
        N_DORMANT["Dormant\nInvisible, matches system notch"]
        N_AMBIENT["Ambient\nSubtle emotion glow border"]
        N_GLANCE["Glanceable\nTimer ring · Emotion · Task card"]
        N_EXPAND["Expanded Panel\nCalendar strip · Mode switcher\nQuick capture · Dashboard stats"]
        N_ALERT["Alert Overlay\nIntervention banner\n5 severity tiers"]
        N_DORMANT -->|"Hover detected"| N_GLANCE
        N_DORMANT -->|"Background state change"| N_AMBIENT
        N_GLANCE -->|"Click / expand"| N_EXPAND
        N_GLANCE -->|"Mouse leave"| N_DORMANT
        N_EXPAND -->|"Close / timeout"| N_DORMANT
        N_AMBIENT -->|"Hover"| N_GLANCE
        N_ALERT -->|"Acknowledged / timeout"| N_DORMANT
    end

    DELIVER --> N_ALERT
    MONITOR --> N_DORMANT

    %% ── Brain Dump Flow ────────────────────────────────────────
    subgraph BRAINDUMP ["Brain Dump (Cmd+Shift+B)"]
        direction TB
        BD_TRIGGER["User presses Cmd+Shift+B"]
        BD_PANEL["FloatingPanel opens\nQuickCaptureField"]
        BD_TYPE["User types brain dump"]
        BD_POST["POST /api/v1/brain-dump/stream"]
        BD_CAPTURE["Store in Mem0\n(type=brain_dump, session, emotion)"]
        BD_SUMMARY["AI Summary via\nQwen3-4B MLX (SSE stream)"]
        BD_DONE["Show summary\nPanel auto-dismisses"]
        BD_TRIGGER --> BD_PANEL --> BD_TYPE --> BD_POST
        BD_POST --> BD_CAPTURE --> BD_SUMMARY --> BD_DONE
    end

    MONITOR --> BD_TRIGGER

    %% ── Vent Modal Flow ────────────────────────────────────────
    subgraph VENTMODAL ["Vent Modal (Cmd+Shift+V)"]
        direction TB
        VM_TRIGGER["User presses Cmd+Shift+V"]
        VM_PANEL["FloatingPanel opens\nVent chat interface"]
        VM_TYPE["User types message"]
        VM_POST["POST /api/v1/vent/chat/stream"]
        VM_SAFETY["4-Layer Safety Check"]
        VM_L1["Layer 1: Crisis keyword scan"]
        VM_L2["Layer 2: SenticNet semantic analysis"]
        VM_L3["Layer 3: Output safety (post-gen)"]
        VM_L4["Layer 4: Session escalation tracking"]
        VM_LLM["Qwen3-4B generates response\n(SSE stream tokens)"]
        VM_REPLY["Stream response to UI"]
        VM_TRIGGER --> VM_PANEL --> VM_TYPE --> VM_POST --> VM_SAFETY
        VM_SAFETY --> VM_L1
        VM_L1 -->|"Crisis detected"| CRISIS_VM[Return crisis resources\nNo LLM]
        VM_L1 -->|"Safe"| VM_L2 --> VM_LLM --> VM_L3 --> VM_L4 --> VM_REPLY
    end

    MONITOR --> VM_TRIGGER

    %% ── Task Creation + Focus Session ──────────────────────────
    subgraph TASKCREATE ["Task Creation (Cmd+Shift+T)"]
        direction TB
        TC_TRIGGER["User presses Cmd+Shift+T"]
        TC_PANEL["TaskCreation panel opens\nName + Duration fields"]
        TC_SUBMIT["POST /api/v1/tasks/create\n{name, duration_seconds}"]
        TC_FOCUS["Focus session starts\nTimer ring in Notch"]
        TC_MONITOR["Off-task detection active\nEmbedding similarity check"]
        TC_COMPLETE["POST /api/v1/tasks/{id}/complete\nor timer expires"]
        TC_TRIGGER --> TC_PANEL --> TC_SUBMIT --> TC_FOCUS
        TC_FOCUS --> TC_MONITOR --> TC_COMPLETE
    end

    MONITOR --> TC_TRIGGER

    %% ── Chat / Venting Flow (Telegram) ─────────────────────────
    TELE --> TELE_HANDLER{Message Type?}
    TELE_HANDLER -->|"/start"| TELE_WELCOME[Welcome message +\ninstructions]
    TELE_HANDLER -->|"Text message"| VENT[POST /chat/message\n(default: vent handler)]
    VENT --> SENTIC[SenticNet Analysis\n4-Dimension Emotion Profile]

    SENTIC --> SAFETY{Safety\nCritical?}
    SAFETY -->|Yes — Depression/Toxicity| CRISIS[Return Crisis Resources\nNo LLM · Hardcoded Response\nSOS CareText · IMH Helpline]
    SAFETY -->|No| LLM[Local LLM Inference\nQwen3-4B via Apple MLX\nEmotion-Informed Coaching]
    LLM --> ACTIONS[Generate Suggested Actions\nMax 3 Quick-Reply Buttons]
    ACTIONS --> MEMORY_STORE[Store in Mem0\nSemantic Memory]
    MEMORY_STORE --> REPLY[Send Reply to User\nvia Telegram]

    %% ── Scheduled Jobs (Telegram Bot) ──────────────────────────
    subgraph SCHEDULED ["Telegram Bot Scheduled Jobs"]
        direction TB
        MORNING["☀️ Morning Briefing\n7:30 AM Daily"]
        FOCUS_SCHED["🎯 Focus Check\nEvery 30 min (9 AM–10 PM)\nConditional: only if distracted"]
        WEEKLY["📊 Weekly Review\nSunday 8 PM"]
    end

    MORNING --> WHOOP_FETCH[GET /whoop/morning-briefing]
    WHOOP_FETCH --> BRIEFING{Recovery\nTier?}
    BRIEFING -->|"🟢 Green (67-100%)"| MSG_GREEN[Full focus blocks\nOptimistic message]
    BRIEFING -->|"🟡 Yellow (34-66%)"| MSG_YELLOW[Shorter blocks\nPace yourself message]
    BRIEFING -->|"🔴 Red (0-33%)"| MSG_RED[Easy tasks only\nSelf-compassion message]
    MSG_GREEN --> SEND_MSG[Send to User via Telegram]
    MSG_YELLOW --> SEND_MSG
    MSG_RED --> SEND_MSG

    FOCUS_SCHED --> FOCUS_CHECK[GET /insights/current]
    FOCUS_CHECK --> FOCUS_GATE{Distracted OR\nHyperfocused > 3h?}
    FOCUS_GATE -->|Yes| FOCUS_MSG[Send Contextual Nudge]
    FOCUS_GATE -->|No — All Good| SILENT[Stay Silent\nAvoid Notification Fatigue]

    WEEKLY --> WEEKLY_DATA[GET /insights/weekly]
    WEEKLY_DATA --> WEEKLY_MSG[Generate 3-4 Sentence\nWeekly Summary + 1 Insight]
    WEEKLY_MSG --> SEND_MSG

    %% ── Google Calendar ────────────────────────────────────────
    subgraph GCAL ["Google Calendar Integration"]
        direction TB
        GCAL_AUTH["GET /api/auth/google\nBrowser OAuth redirect"]
        GCAL_CALLBACK["GET /api/auth/google/callback\nToken stored"]
        GCAL_EVENTS["GET /api/v1/calendar/upcoming\nFetch next 3 events"]
        GCAL_STRIP["Calendar strip in\nNotch Expanded panel"]
        GCAL_AUTH --> GCAL_CALLBACK --> GCAL_EVENTS --> GCAL_STRIP
    end

    START --> GCAL_AUTH

    %% ── Dashboard Flow ──────────────────────────────────────────
    DASH --> API_CALL[GET /insights/dashboard\nPolling Every 5s]
    API_CALL --> DASHBOARD_RENDER

    subgraph DASHBOARD_RENDER ["Dashboard Components"]
        direction TB
        D1["📊 FocusTimeline\nColor-coded activity bar\n🟢 Focused · 🔴 Distracted · 🟡 Neutral · ⚪ Idle"]
        D2["🧭 EmotionRadar\nHourglass of Emotions radar chart\n4 axes: Pleasantness · Attention · Sensitivity · Aptitude"]
        D3["💚 WhoopCard\nRecovery score · HRV · Sleep\nRecommended focus block"]
        D4["⚡ MetricsCard\nLive: switches · focus % · streak\nToday: focus time · active time"]
        D5["🔔 InterventionLog\nTriggered · Accepted · Rate\nBehavioral state breakdown"]
        D6["📈 WeeklyReport\nBar chart: Focus vs Distraction\nTrend · Top apps · Best/worst day"]
    end

    %% ── Whoop Setup ─────────────────────────────────────────────
    START --> WHOOP_SETUP[Connect Whoop]
    WHOOP_SETUP --> WHOOPSKILL_CLI[Run: whoopskill auth login]
    WHOOPSKILL_CLI --> WHOOP_OAUTH[Browser OAuth Flow]
    WHOOP_OAUTH --> WHOOP_CALLBACK[GET /api/auth/whoop]
    WHOOP_CALLBACK --> WHOOP_TOKEN[Token Saved to\n~/.whoop-cli/tokens.json]
    WHOOP_TOKEN --> WHOOP_READY[Whoop Data Available\nfor Dashboard + Morning Briefing]

    %% ── Menu Bar Interaction ────────────────────────────────────
    MONITOR --> MENUBAR[Menu Bar Display]
    MENUBAR --> VIEW_METRICS[View: State Emoji · Focus % ·\nSwitches · Streak · Health Dot]
    VIEW_METRICS --> PAUSE{User Action}
    PAUSE -->|Pause| TOGGLE[Toggle Monitoring Off]
    PAUSE -->|Resume| MONITOR
    PAUSE -->|Settings| ONBOARD
    PAUSE -->|Quit| QUIT([App Terminates])

    %% ── Daily Snapshots ─────────────────────────────────────────
    subgraph SNAPSHOTS ["Daily Snapshots (Background)"]
        direction TB
        SNAP_CHECK["Check time every 60s"]
        SNAP_SAVE["Save snapshot at 23:55\ntotal_focus · distraction · switches\ntop_apps · emotion_scores · whoop"]
        SNAP_BACKFILL["On startup: backfill\nyesterday if missing"]
        SNAP_HISTORY["GET /api/v1/dashboard/history\nBrowse in Swift History view"]
        SNAP_CHECK --> SNAP_SAVE
        SNAP_BACKFILL --> SNAP_HISTORY
    end

    %% ── Styling ─────────────────────────────────────────────────
    classDef entry fill:#6366f1,stroke:#4f46e5,color:#fff,font-weight:bold
    classDef decision fill:#1e1b4b,stroke:#6366f1,color:#e4e4e7
    classDef action fill:#1a1d27,stroke:#2e3348,color:#e4e4e7
    classDef safe fill:#166534,stroke:#22c55e,color:#fff
    classDef danger fill:#7f1d1d,stroke:#ef4444,color:#fff
    classDef warn fill:#713f12,stroke:#eab308,color:#fff
    classDef tier fill:#0c4a6e,stroke:#3b82f6,color:#fff
    classDef notch fill:#1e3a5f,stroke:#3b82f6,color:#fff
    classDef modal fill:#312e81,stroke:#6366f1,color:#fff

    class START,LAUNCH,DASH,TELE,WHOOP_SETUP entry
    class PERM,JITAI,GATES,BREAKPOINT,RESPONSE,SAFETY,BRIEFING,FOCUS_GATE,PAUSE,OFFTASK,OFFTASK_RESULT,TELE_HANDLER decision
    class CRISIS,CRISIS_VM danger
    class MSG_GREEN safe
    class MSG_YELLOW warn
    class MSG_RED danger
    class TIER1,TIER2,TIER3,TIER4,TIER5 tier
    class N_DORMANT,N_AMBIENT,N_GLANCE,N_EXPAND,N_ALERT notch
    class BD_TRIGGER,BD_PANEL,BD_TYPE,BD_POST,BD_CAPTURE,BD_SUMMARY,BD_DONE modal
    class VM_TRIGGER,VM_PANEL,VM_TYPE,VM_POST,VM_SAFETY,VM_LLM,VM_REPLY modal
    class TC_TRIGGER,TC_PANEL,TC_SUBMIT,TC_FOCUS,TC_MONITOR,TC_COMPLETE modal
