\@writefile{lof}{\contentsline {figure}{\numberline {3.1}{\ignorespaces Three-layer system architecture of the ADHD Second Brain. The User Layer comprises a SwiftUI menu bar application, a React dashboard, and a Telegram bot interface. The Backend Layer hosts the FastAPI server (\texttt  {localhost:8420}) with its constituent modules (${\sim }500$\,MB RAM $+$ ${\sim }2.3$\,GB GPU). The Data Layer uses PostgreSQL with pgvector for persistent and vector-indexed storage. Dashed arrows indicate external service calls.}}{23}{figure.caption.12}\protected@file@percent }
\newlabel{fig:system_architecture}{{3.1}{23}{Three-layer system architecture of the ADHD Second Brain. The User Layer comprises a SwiftUI menu bar application, a React dashboard, and a Telegram bot interface. The Backend Layer hosts the FastAPI server (\texttt {localhost:8420}) with its constituent modules (${\sim }500$\,MB RAM $+$ ${\sim }2.3$\,GB GPU). The Data Layer uses PostgreSQL with pgvector for persistent and vector-indexed storage. Dashed arrows indicate external service calls}{figure.caption.12}{}}
\newlabel{fig:system_architecture@cref}{{[figure][1][3]3.1}{[1][22][]23}{}{}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3.2}{\ignorespaces Hot Path and Warm Path data flows. The Hot Path (solid arrows) processes screen monitoring events through activity classification, ADHD metrics computation, SetFit emotion prediction, and JITAI evaluation with confidence-gated emotion context within a 100\,ms budget. The Warm Path (dashed arrows) processes conversational input through a unified SenticNet analysis (safety, emotion, and ADHD signals concurrently), a safety gate, LLM context construction with memory retrieval, LLM generation, and memory storage within a 3\,s budget.}}{24}{figure.caption.13}\protected@file@percent }
\newlabel{fig:data_flows}{{3.2}{24}{Hot Path and Warm Path data flows. The Hot Path (solid arrows) processes screen monitoring events through activity classification, ADHD metrics computation, SetFit emotion prediction, and JITAI evaluation with confidence-gated emotion context within a 100\,ms budget. The Warm Path (dashed arrows) processes conversational input through a unified SenticNet analysis (safety, emotion, and ADHD signals concurrently), a safety gate, LLM context construction with memory retrieval, LLM generation, and memory storage within a 3\,s budget}{figure.caption.13}{}}
\newlabel{fig:data_flows@cref}{{[figure][2][3]3.2}{[1][23][]24}{}{}{}}
